parameters:
  level: 8
  paths:
    - src/
  treatPhpDocTypesAsCertain: false
  scanFiles:
    - .phpstan/stubs/MediaWiki.stub.php
    - .phpstan/stubs/MediaWikiNamespaced.stub.php
  ignoreErrors:
    # MediaWiki File methods have inconsistent signatures
    - '#Method .+::transform\(\) should return ThumbnailImage\|MediaTransformError but returns#'
