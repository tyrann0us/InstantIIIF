{
  "name": "InstantIIIF",
  "version": "1.0.0",
  "author": [
    "[https://github.com/tyrann0us Philipp Bammes]"
  ],
  "url": "https://github.com/tyrann0us/InstantIIIF",
  "descriptionmsg": "instantiiif-desc",
  "license-name": "MIT",
  "type": "other",
  "requires": {
    "MediaWiki": ">= 1.39"
  },
  "load_composer_autoloader": true,
  "AutoloadNamespaces": {
    "MediaWiki\\Extension\\InstantIIIF\\": "src/"
  },
  "config": {
    "InstantIIIFDefaultTimeout": {
      "value": 5,
      "description": "HTTP timeout in seconds for IIIF fetches"
    }
  },
  "manifest_version": 2,
  "MessagesDirs": {
    "InstantIIIF": [
      "i18n"
    ]
  },
  "ResourceFileModulePaths": {
    "localBasePath": "",
    "remoteExtPath": "InstantIIIF"
  },
  "ResourceModules": {
    "ext.instantIIIF.mmvTitlePatch": {
      "scripts": [
        "resources/mmv-title-patch.js"
      ],
      "targets": [
        "desktop",
        "mobile"
      ],
      "dependencies": [
        "mediawiki.Title"
      ],
      "position": "top"
    }
  },
  "Hooks": {
    "BeforePageDisplay": [
      "MediaWiki\\Extension\\InstantIIIF\\Hooks::onBeforePageDisplay"
    ],
    "ThumbnailBeforeProduceHTML": [
      "MediaWiki\\Extension\\InstantIIIF\\Hooks::onThumbnailBeforeProduceHTML"
    ]
  }
}
