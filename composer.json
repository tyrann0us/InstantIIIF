{
  "name": "tyrann0us/instantiiif",
  "description": "MediaWiki Foreign FileRepo that hotlinks images from IIIF sources (Presentation API v2/v3).",
  "license": "MIT",
  "type": "mediawiki-extension",
  "keywords": [
    "mediawiki",
    "iiif",
    "images"
  ],
  "require": {
    "php": ">=8.4",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.0",
    "syde/phpcs": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "MediaWiki\\Extension\\InstantIIIF\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MediaWiki\\Extension\\InstantIIIF\\Tests\\": "tests/phpunit/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "phpcs": "@php ./vendor/bin/phpcs",
    "phpcs:fix": "@php ./vendor/bin/phpcbf",
    "phpstan": "@php ./vendor/bin/phpstan analyse --memory-limit=1G",
    "tests": "@php ./vendor/bin/phpunit",
    "tests:coverage": "@php ./vendor/bin/phpunit --coverage-text"
  }
}
