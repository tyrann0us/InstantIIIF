{
    "name": "instantiiif",
    "description": "MediaWiki extension to provide a `FileRepo` for file links (`[[File:...]]`) that hotlinks images from IIIF sources (Presentation API v2/v3).",
    "license": "MIT",
    "version": "1.0.0",
    "author": {
        "name": "Syde GmbH",
        "email": "hello@syde.com",
        "url": "https://syde.com/"
    },
    "engines": {
        "node": "~18.0"
    },
    "devDependencies": {
        "@wordpress/scripts": "^32.1.0",
        "@playwright/test": "^1.49.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0"
    },
    "scripts": {
        "lint:md": "wp-scripts lint-md-docs README.md docs/**/*.md",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:e2e": "npx playwright test --config=tests/playwright/playwright.config.js",
        "test:e2e:headed": "npx playwright test --config=tests/playwright/playwright.config.js --headed",
        "docker:up": "docker compose up -d && docker compose exec wiki bash /var/www/html/extensions/InstantIIIF/.docker/setup-wiki.sh",
        "docker:down": "docker compose down -v"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "testMatch": [
            "<rootDir>/tests/jest/**/*.test.js"
        ],
        "resetModules": true
    }
}
